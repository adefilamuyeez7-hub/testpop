{
  "buildCommand": "npm run build:vercel",
  "builds": [
    {
      "src": "server/api/index.js",
      "use": "@vercel/node",
      "config": {
        "maxLambdaSize": "50mb",
        "nodeVersion": "20.x"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server/api/index.js"
    },
    {
      "src": "/health",
      "dest": "server/api/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "server/api/index.js"
    }
  ]
}
