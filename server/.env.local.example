# ═══════════════════════════════════════════════════════════════════════════════
# SERVER BACKEND ENVIRONMENT CONFIGURATION (Local Development)
# ═══════════════════════════════════════════════════════════════════════════════
# Copy this to .env.local and replace placeholder values
#
# ⚠️  SECURITY: Never commit .env.local to version control!
# Add .env.local to .gitignore (it already is)

# ── API Server Configuration ────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
# For local dev: http://localhost:5173
# For production: https://testpop-one.vercel.app
# For both: http://localhost:5173,https://testpop-one.vercel.app
FRONTEND_ORIGIN=http://localhost:5173,http://localhost:8080,https://testpop-one.vercel.app

# ── Pinata IPFS Configuration ──────────────────────────────────────────────────
# Required for file uploads (art images, metadata, etc.)
# Get your JWT from: https://app.pinata.cloud/developers/tokens
PINATA_JWT=3d2acbb77b762b35dcd5...

# ── Supabase Backend Configuration ─────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://hdqgpqjpmzkipvfxtsku.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImhkcWdwcWpwbXpraXB2Znh0c2t1Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzYyMzIxMTAsImV4cCI6MjA5MTgwODExMH0.Hx9OyP19U8hzIrHAj5qLo8AW9CFTCLg6R1zgI1UkfRc
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImhkcWdwcWpwbXpraXB2Znh0c2t1Iiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc3NjIzMjExMCwiZXhwIjoyMDkxODA4MTEwfQ.EPVYvx4yqHjMbFC_QL0Vm_KeNViTe8f60BGelGLSbxQ

# ── JWT Authentication Configuration ───────────────────────────────────────────
# Used to sign auth tokens (wallet verification, admin claims, etc.)
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
APP_JWT_SECRET=your_super_secure_random_string_change_in_production

# ── Admin Authorization ────────────────────────────────────────────────────────
# Comma-separated list of wallet addresses that get admin panel access
# Must be lowercase (no ERC-55 checksums)
ADMIN_WALLETS=0x4b393730efc0e3c1e0c0944fbf05edef4ee58092

# ── Base Sepolia RPC (Optional) ────────────────────────────────────────────────
# If not set, defaults to public endpoint
# For production, use: https://mainnet.base.org or Alchemy/Infura endpoint
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# ═══════════════════════════════════════════════════════════════════════════════
# PRODUCTION DEPLOYMENT (Vercel)
# Set these in Vercel Dashboard → Settings → Environment Variables
# ═══════════════════════════════════════════════════════════════════════════════
#
# All production env vars should match the above keys and values from your
# production Pinata account, Supabase instance, etc.
#
# Production checklist:
# ✓ PINATA_JWT - Production Pinata JWT token
# ✓ SUPABASE_* - Production Supabase project credentials
# ✓ APP_JWT_SECRET - Strong random value (minimum 32 characters)
# ✓ ADMIN_WALLETS - Your actual admin wallet addresses
# ✓ NODE_ENV=production
