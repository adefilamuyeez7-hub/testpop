# ⚠️  SECURITY WARNING: Never commit private keys to version control!
# Use environment variables in secure CI/CD pipelines only
# For local development, use a test wallet with no real funds
# PRIVATE_KEY=your_private_key_here_without_0x_prefix

# Deployed Contract Addresses - Base Sepolia
VITE_FACTORY_ADDRESS=0xFd58d0f5F0423201Edb756d0f44D667106fc5705
VITE_ARTIST_SHARES_ADDRESS=0x6CCDAD96591d0Bd2e97070dD2a96E56d7ce6BC97
VITE_POAP_CAMPAIGN_ADDRESS=0x0fcb25EA06cB29296080C203119c25f9923A02ad
VITE_PRODUCT_STORE_ADDRESS=0x58BB50b4370898dED4d5d724E4A521825a4B0cE6

# Supabase Configuration (get from https://supabase.com/dashboard)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# Trusted backend base URL for writes and IPFS uploads
VITE_SECURE_API_BASE_URL=https://your-api.example.com
VITE_PINATA_API_BASE_URL=https://your-api.example.com/api/pinata

# WalletConnect Project ID (get from https://cloud.walletconnect.com)
VITE_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id_here

# Admin & Founder Wallet Addresses (REQUIRED - set these for admin panel access)
# Note: Change to your actual wallet addresses in .env.local and Vercel settings
VITE_ADMIN_WALLET=0x0000000000000000000000000000000000000000
VITE_FOUNDER_WALLET=0x0000000000000000000000000000000000000000

# RPC Endpoints (optional - will use public endpoints if not set)
VITE_BASE_RPC_URL=https://mainnet.base.org
VITE_BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Backend must issue signed JWT/session tokens carrying wallet + role claims for protected writes

# ── Waitlist Integration ──────────────────────────────────────────────────────
# The waitlist site writes to the same Supabase project.
# No extra config needed — getWaitlistEntry() in db.ts reads from the shared
# waitlist table automatically using VITE_SUPABASE_URL above.
